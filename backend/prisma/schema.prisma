// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  PROFESSIONAL
}

enum AppointmentStatus {
  SCHEDULED
  ATTENDED
  CANCELED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  PIX
  CARD
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  SUSPENDED
}

enum TransactionType {
  EXPENSE
  REVENUE
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum PaymentCondition {
  A_VISTA
  A_PRAZO
}

enum PaymentMethodScope {
  COMANDA
  EXPENSE
  BOTH
}

enum CommissionStatus {
  PENDING
  PAID
}

// ============================================
// MODELS
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  professional       Professional?  @relation("UserProfessional")
  openedRegisters    CashRegister[] @relation("OpenedBy")
  closedRegisters    CashRegister[] @relation("ClosedBy")
  registeredPayments Payment[]      @relation("RegisteredBy")

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique // AJUSTE 1: Opcional - muitos clientes de barbearia não têm email
  phone     String
  password  String?  // Null se usar Google OAuth
  googleId  String?  @unique
  hasDebts  Boolean  @default(false) // AJUSTE 2: Campo derivável, mas mantido para performance - atualizar sempre que debts mudar
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  appointments Appointment[]
  payments     Payment[]
  debts        Debt[]
  subscription ClientSubscription?
  orders       Order[]

  @@map("clients")
}

model Professional {
  id             String   @id @default(uuid())
  name           String
  phone          String
  email          String?
  commissionRate Decimal? @db.Decimal(5, 2) // Ex: 50.00 para 50%
  workingHours   Json?    // Array de { dayOfWeek: number, startTime: string, endTime: string }
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relacionamentos
  userId       String?       @unique
  user         User?         @relation("UserProfessional", fields: [userId], references: [id])
  branchId     String?
  branch       Branch?       @relation(fields: [branchId], references: [id])
  appointments Appointment[]
  services     Service[]
  commissions  Commission[]
  orders       Order[]
  timeBlocks   TimeBlock[]

  @@map("professionals")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int      // Preço em centavos (ex: 5000 = R$ 50,00)
  duration    Int      // Duração em minutos
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  professionals       Professional[]
  appointmentServices AppointmentService[]
  orderItems          OrderItem[]

  @@map("services")
}

model Appointment {
  id            String            @id @default(uuid())
  scheduledAt   DateTime
  status        AppointmentStatus @default(SCHEDULED)
  totalPrice    Int               // Preço total em centavos
  totalDuration Int               // Duração total em minutos
  isPaid        Boolean           @default(false)
  notes         String?
  attendedAt    DateTime?
  canceledAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relacionamentos
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  services AppointmentService[]
  payment  Payment?
  debts    Debt[]

  @@map("appointments")
}

model AppointmentService {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relacionamentos
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@map("appointment_services")
}

model Payment {
  id        String        @id @default(uuid())
  amount    Int           // Valor em centavos
  method    PaymentMethod
  paidAt    DateTime
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relacionamentos
  appointmentId String?      @unique // AJUSTE 3: @unique mantido - 1 pagamento por agendamento (sem parcelamento no escopo atual)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  registeredBy     String
  registeredByUser User   @relation("RegisteredBy", fields: [registeredBy], references: [id])

  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  order Order?

  @@map("payments")
}

model Debt {
  id               String    @id @default(uuid())
  amount           Int       // Valor total da dívida em centavos
  amountPaid       Int       @default(0) // Valor já pago em centavos
  remainingBalance Int       // Saldo restante em centavos
  description      String?
  dueDate          DateTime?
  paidAt           DateTime?
  isSettled        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relacionamentos
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("debts")
}

model CashRegister {
  id             String    @id @default(uuid())
  date           DateTime  @unique @db.Date // AJUSTE 4: Data do caixa - SEMPRE normalizar para 00:00:00 no código
  openedAt       DateTime
  openingBalance Int       // Saldo inicial em centavos
  closedAt       DateTime?
  closingBalance Int?      // Saldo final em centavos
  totalCash      Int?      // Total em dinheiro
  totalPix       Int?      // Total em Pix
  totalCard      Int?      // Total em cartão
  totalRevenue   Int?      // Receita total do dia
  discrepancy    Int?      // Diferença entre esperado e real
  notes          String?
  isOpen         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relacionamentos
  openedBy     String
  openedByUser User   @relation("OpenedBy", fields: [openedBy], references: [id])

  closedBy     String?
  closedByUser User?   @relation("ClosedBy", fields: [closedBy], references: [id])

  payments Payment[]

  @@map("cash_registers")
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String   // "Plano Mensal", "Plano Trimestral"
  description  String?
  price        Int      // Preço em centavos (ex: 9900 = R$ 99,00)
  cutsPerMonth Int      // Número de cortes permitidos por mês
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relacionamentos
  subscriptions ClientSubscription[]

  @@map("subscription_plans")
}

model ClientSubscription {
  id                String             @id @default(uuid())
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime           @default(now())
  endDate           DateTime?          // null = ativa indefinidamente
  cutsUsedThisMonth Int                @default(0)
  lastResetDate     DateTime           @default(now()) // Quando os cortes foram resetados
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relacionamentos
  clientId String @unique // Cliente só pode ter 1 assinatura ativa
  client   Client @relation(fields: [clientId], references: [id])

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("client_subscriptions")
}

// ============================================
// ESTOQUE / PRODUTOS
// ============================================

enum StockMovementType {
  ENTRY
  EXIT
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  costPrice   Int      // Preco de custo em centavos
  salePrice   Int      // Preco de venda em centavos
  minStock    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  branchId       String?
  branch         Branch?         @relation(fields: [branchId], references: [id])
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@map("products")
}

model StockMovement {
  id        String            @id @default(uuid())
  type      StockMovementType
  quantity  Int
  reason    String?
  createdAt DateTime          @default(now())

  // Relacionamentos
  productId String
  product   Product @relation(fields: [productId], references: [id])
  branchId  String?
  branch    Branch? @relation(fields: [branchId], references: [id])
  createdBy String?

  @@map("stock_movements")
}

// ============================================
// COMANDAS / ORDERS
// ============================================

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

enum OrderItemType {
  PRODUCT
  SERVICE
}

model Order {
  id          String      @id @default(uuid())
  status      OrderStatus @default(PENDING)
  totalAmount Int         @default(0) // centavos
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relacionamentos
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id])
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  paymentId      String?       @unique
  payment        Payment?      @relation(fields: [paymentId], references: [id])
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String        @id @default(uuid())
  quantity  Int           @default(1)
  unitPrice Int           // centavos
  itemType  OrderItemType

  // Relacionamentos
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  @@map("order_items")
}

// ============================================
// BLOQUEIO DE HORARIOS
// ============================================

model TimeBlock {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())

  // Relacionamentos
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  @@map("time_blocks")
}

// ============================================
// MÓDULO FINANCEIRO
// ============================================

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  professionals  Professional[]
  transactions   FinancialTransaction[]
  commissions    Commission[]
  products       Product[]
  stockMovements StockMovement[]
  orders         Order[]

  @@map("branches")
}

model BankAccount {
  id          String   @id @default(uuid())
  name        String
  bank        String?
  accountType String?  // "Conta corrente", "Conta poupança", etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  transactions FinancialTransaction[]

  @@map("bank_accounts")
}

model FinancialCategory {
  id        String          @id @default(uuid())
  name      String
  type      TransactionType // EXPENSE ou REVENUE
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Self-relation para subcategorias
  parentId String?
  parent   FinancialCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children FinancialCategory[] @relation("CategoryHierarchy")

  // Relacionamentos
  transactions    FinancialTransaction[] @relation("TransactionCategory")
  subTransactions FinancialTransaction[] @relation("TransactionSubcategory")

  @@map("financial_categories")
}

model PaymentMethodConfig {
  id        String             @id @default(uuid())
  name      String
  type      PaymentCondition   // A_VISTA ou A_PRAZO
  scope     PaymentMethodScope // COMANDA, EXPENSE ou BOTH
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // Relacionamentos
  transactions FinancialTransaction[]

  @@map("payment_method_configs")
}

model FinancialTransaction {
  id               String            @id @default(uuid())
  type             TransactionType   // EXPENSE ou REVENUE
  description      String
  amount           Int               // Valor em centavos
  discount         Decimal?          @db.Decimal(5, 2) // Percentual de desconto
  interest         Decimal?          @db.Decimal(5, 2) // Percentual de juros
  netAmount        Int               // Valor líquido em centavos (calculado: amount - desconto + juros)
  paymentCondition PaymentCondition
  status           TransactionStatus @default(PENDING)
  isRecurring      Boolean           @default(false)
  dueDate          DateTime
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relacionamentos
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  categoryId String
  category   FinancialCategory @relation("TransactionCategory", fields: [categoryId], references: [id])

  subcategoryId String?
  subcategory   FinancialCategory? @relation("TransactionSubcategory", fields: [subcategoryId], references: [id])

  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  paymentMethodConfigId String?
  paymentMethodConfig   PaymentMethodConfig? @relation(fields: [paymentMethodConfigId], references: [id])

  @@map("financial_transactions")
}

model Commission {
  id          String           @id @default(uuid())
  amount      Int              // Valor da comissão em centavos
  periodStart DateTime
  periodEnd   DateTime
  status      CommissionStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relacionamentos
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  @@map("commissions")
}
